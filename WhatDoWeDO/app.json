{
  "expo": {
    "name": "WhatDoWeDO",
    "slug": "whatdowedo",
    "scheme": "whatdowedo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5A5F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.whatdowedo.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WhatDoWeDO ha bisogno della tua posizione per mostrarti gli eventi vicino a te."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF5A5F"
      },
      "package": "com.anonymous.whatdowedo",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleMapsApiKey": "AIzaSyBmoVeB4NdwBLWa8rgHd9IsPy0E5mI5Jno"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "WhatDoWeDO ha bisogno della tua posizione per mostrarti gli eventi vicino a te."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepositories": []
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "616df0e9-5779-4740-983f-ec3eec9e8623"
      }
    }
  }
}
